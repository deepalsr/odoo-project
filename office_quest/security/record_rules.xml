<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Users can only see their own hero profile -->
    <record id="rule_game_profile_user" model="ir.rule">
        <field name="name">Game Profile: Users see own profile</field>
        <field name="model_id" ref="model_game_profile"/>
        <field name="groups" eval="[(4, ref('office_quest.group_office_quest_user'))]"/>
        <field name="domain_force">
            [('id', '=', user.profile_id.id)]
        </field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- Managers can see all hero profiles -->
    <record id="rule_game_profile_manager" model="ir.rule">
        <field name="name">Game Profile: Managers see all profiles</field>
        <field name="model_id" ref="model_game_profile"/>
        <field name="groups" eval="[(4, ref('office_quest.group_office_quest_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- XP Log: users can only read their own hero's logs -->
    <record id="rule_xp_log_user_own" model="ir.rule">
        <field name="name">XP Log: User sees own hero logs only</field>
        <field name="model_id" ref="model_game_xp_log"/>
        <field name="groups" eval="[(4, ref('office_quest.group_office_quest_user'))]"/>
        <field name="domain_force">
            [('profile_id', '=', user.profile_id.id)]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- XP Log: managers can see all logs -->
    <record id="rule_xp_log_manager" model="ir.rule">
        <field name="name">XP Log: Managers see all logs</field>
        <field name="model_id" ref="model_game_xp_log"/>
        <field name="groups" eval="[(4, ref('office_quest.group_office_quest_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>