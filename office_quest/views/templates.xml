<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- BASE LAYOUT -->
    <template id="quest_layout" name="Office Quest Layout">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'quest'"/>

            <!-- Global Styles -->
            <style>
                body {
                    background: #0d0d1a;
                    color: #e0e0e0;
                    font-family: 'Segoe UI', sans-serif;
                }
                .quest-nav {
                    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
                    border-bottom: 2px solid #FFD700;
                    padding: 12px 0;
                    position: sticky;
                    top: 0;
                    z-index: 1000;
                    box-shadow: 0 2px 20px rgba(255,215,0,0.2);
                }
                .quest-nav .navbar-brand {
                    color: #FFD700;
                    font-size: 1.5rem;
                    font-weight: 900;
                    letter-spacing: 1px;
                    text-shadow: 0 0 10px rgba(255,215,0,0.5);
                    text-decoration: none;
                }
                .quest-nav .nav-link {
                    color: #c0c0c0 !important;
                    font-weight: 600;
                    padding: 6px 16px;
                    border-radius: 20px;
                    transition: all 0.3s;
                    text-decoration: none;
                }
                .quest-nav .nav-link:hover {
                    color: #FFD700 !important;
                    background: rgba(255,215,0,0.1);
                }
                .quest-nav .nav-link.manager {
                    color: #FFD700 !important;
                    border: 1px solid #FFD700;
                }
                .quest-nav .nav-link.manager:hover {
                    background: #FFD700;
                    color: #0d0d1a !important;
                }
                .quest-wrap {
                    min-height: 100vh;
                    background: #0d0d1a;
                }
                .quest-container {
                    max-width: 1200px;
                    margin: 0 auto;
                    padding: 40px 20px;
                }
                .quest-title {
                    color: #FFD700;
                    font-weight: 900;
                    font-size: 2.5rem;
                    text-shadow: 0 0 20px rgba(255,215,0,0.4);
                    letter-spacing: 2px;
                }
                .quest-subtitle {
                    color: #888;
                    font-size: 1rem;
                    letter-spacing: 1px;
                }
                .hero-card {
                    background: linear-gradient(145deg, #1a1a2e, #16213e);
                    border-radius: 16px;
                    border: 2px solid #2a2a4a;
                    padding: 24px;
                    transition: all 0.3s ease;
                    position: relative;
                    overflow: hidden;
                }
                .hero-card::before {
                    content: '';
                    position: absolute;
                    top: 0; left: 0; right: 0;
                    height: 3px;
                    background: linear-gradient(90deg, transparent, #FFD700, transparent);
                    opacity: 0;
                    transition: opacity 0.3s;
                }
                .hero-card:hover {
                    transform: translateY(-4px);
                    border-color: #FFD700;
                    box-shadow: 0 8px 30px rgba(255,215,0,0.2);
                }
                .hero-card:hover::before {
                    opacity: 1;
                }
                .hero-card.gold {
                    border-color: #FFD700;
                    box-shadow: 0 0 20px rgba(255,215,0,0.3);
                }
                .hero-card.silver {
                    border-color: #C0C0C0;
                    box-shadow: 0 0 20px rgba(192,192,192,0.2);
                }
                .hero-card.bronze {
                    border-color: #CD7F32;
                    box-shadow: 0 0 20px rgba(205,127,50,0.2);
                }
                .hero-name {
                    font-size: 1.2rem;
                    font-weight: 800;
                    color: #ffffff;
                    margin-bottom: 4px;
                }
                .hero-class-badge {
                    display: inline-block;
                    padding: 3px 12px;
                    border-radius: 20px;
                    font-size: 0.75rem;
                    font-weight: 700;
                    margin-bottom: 12px;
                    letter-spacing: 1px;
                }
                .class-warrior { background: rgba(231,76,60,0.2); color: #e74c3c; border: 1px solid #e74c3c; }
                .class-wizard  { background: rgba(142,68,173,0.2); color: #9b59b6; border: 1px solid #9b59b6; }
                .class-healer  { background: rgba(39,174,96,0.2);  color: #2ecc71; border: 1px solid #2ecc71; }
                .class-rogue   { background: rgba(52,73,94,0.5);   color: #95a5a6; border: 1px solid #7f8c8d; }
                .xp-bar-wrap {
                    background: #0d0d1a;
                    border-radius: 10px;
                    height: 10px;
                    margin: 8px 0 4px;
                    overflow: hidden;
                    border: 1px solid #2a2a4a;
                }
                .xp-bar-fill {
                    height: 100%;
                    border-radius: 10px;
                    background: linear-gradient(90deg, #FFD700, #FFA500);
                    box-shadow: 0 0 8px rgba(255,215,0,0.6);
                    transition: width 1s ease;
                }
                .xp-text {
                    color: #888;
                    font-size: 0.75rem;
                }
                .xp-amount {
                    color: #FFD700;
                    font-weight: 700;
                    font-size: 0.95rem;
                }
                .quest-badge {
                    display: inline-block;
                    background: rgba(255,215,0,0.1);
                    border: 1px solid rgba(255,215,0,0.3);
                    color: #FFD700;
                    border-radius: 20px;
                    padding: 2px 10px;
                    font-size: 0.75rem;
                    margin: 2px;
                }
                .rank-medal {
                    font-size: 1.4rem;
                    margin-right: 4px;
                }
                .profile-card {
                    background: linear-gradient(145deg, #1a1a2e, #16213e);
                    border: 2px solid #FFD700;
                    border-radius: 20px;
                    padding: 32px;
                    text-align: center;
                    box-shadow: 0 0 30px rgba(255,215,0,0.2);
                }
                .profile-avatar {
                    font-size: 4rem;
                    margin-bottom: 12px;
                }
                .profile-name {
                    font-size: 1.8rem;
                    font-weight: 900;
                    color: #FFD700;
                    text-shadow: 0 0 10px rgba(255,215,0,0.4);
                }
                .profile-level {
                    color: #888;
                    font-size: 0.95rem;
                    margin-bottom: 16px;
                }
                .xp-log-item {
                    background: #1a1a2e;
                    border-radius: 10px;
                    padding: 14px 18px;
                    margin-bottom: 10px;
                    border-left: 4px solid;
                    transition: transform 0.2s;
                }
                .xp-log-item:hover {
                    transform: translateX(4px);
                }
                .xp-log-item.positive { border-color: #2ecc71; }
                .xp-log-item.negative { border-color: #e74c3c; }
                .xp-amount-positive { color: #2ecc71; font-weight: 800; font-size: 1.1rem; }
                .xp-amount-negative { color: #e74c3c; font-weight: 800; font-size: 1.1rem; }
                .xp-log-reason { color: #aaa; font-size: 0.85rem; margin-top: 2px; }
                .xp-log-date { color: #555; font-size: 0.75rem; }
                .quest-table {
                    width: 100%;
                    border-collapse: separate;
                    border-spacing: 0 6px;
                }
                .quest-table thead th {
                    background: #16213e;
                    color: #FFD700;
                    padding: 12px 16px;
                    font-size: 0.8rem;
                    letter-spacing: 1px;
                    text-transform: uppercase;
                    border: none;
                }
                .quest-table tbody tr {
                    background: #1a1a2e;
                    transition: all 0.2s;
                }
                .quest-table tbody tr:hover {
                    background: #16213e;
                    transform: scale(1.005);
                }
                .quest-table tbody td {
                    padding: 12px 16px;
                    color: #e0e0e0;
                    border: none;
                    vertical-align: middle;
                }
                .quest-table tbody tr.positive td:first-child {
                    border-left: 3px solid #2ecc71;
                }
                .quest-table tbody tr.negative td:first-child {
                    border-left: 3px solid #e74c3c;
                }
                .section-title {
                    color: #FFD700;
                    font-weight: 800;
                    font-size: 1.3rem;
                    margin-bottom: 20px;
                    padding-bottom: 8px;
                    border-bottom: 1px solid #2a2a4a;
                }
                .badge-active   { background: rgba(46,204,113,0.2); color: #2ecc71; border: 1px solid #2ecc71; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; }
                .badge-inactive { background: rgba(127,140,141,0.2); color: #7f8c8d; border: 1px solid #7f8c8d; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; }
                .empty-state {
                    text-align: center;
                    padding: 60px 20px;
                    color: #555;
                    font-size: 1.1rem;
                }
                .badge-goal-bar {
                    background: #0d0d1a;
                    border-radius: 10px;
                    height: 10px;
                    margin: 6px 0 4px;
                    overflow: hidden;
                    border: 1px solid #2a2a4a;
                }
                .badge-goal-fill {
                    height: 100%;
                    border-radius: 10px;
                    background: linear-gradient(90deg, #8e44ad, #9b59b6);
                    box-shadow: 0 0 8px rgba(155,89,182,0.6);
                    transition: width 1s ease;
                }
            </style>

            <!-- Hide Odoo default header and footer -->
            <style>
                header.o_header_standard,
                header#top,
                div#oe_main_menu_navbar,
                .o_main_navbar,
                .o_header_hide_on_scroll,
                footer.o_footer,
                footer#bottom,
                .o_website_logo,
                #wrapwrap > footer {
                    display: none !important;
                }
                body, #wrapwrap {
                    padding-top: 0 !important;
                    margin-top: 0 !important;
                }
            </style>

            <div class="quest-wrap">
                <!-- NAV -->
                <nav class="quest-nav">
                    <div class="container d-flex justify-content-between align-items-center">
                        <a class="navbar-brand" href="/quest">⚔️ Office Quest</a>
                        <div class="d-flex gap-2">
                            <a href="/quest" class="nav-link">🏆 Leaderboard</a>
                            <t t-if="request.env.user.id != request.env.ref('base.public_user').id">
                                <a href="/quest/my" class="nav-link">🧙 My Profile</a>
                                <t t-if="request.env.user.has_group('office_quest.group_office_quest_manager')">
                                    <a href="/quest/manage" class="nav-link manager">⚙️ Manage</a>
                                </t>
                            </t>
                            <t t-else="">
                                <a href="/web/login" class="nav-link">🔑 Login</a>
                            </t>
                        </div>
                    </div>
                </nav>

                <!-- PAGE CONTENT -->
                <div class="quest-container">
                    <t t-out="0"/>
                </div>
            </div>
        </t>
    </template>

    <!-- LEADERBOARD PAGE -->
    <template id="quest_leaderboard" name="Quest Leaderboard">
        <t t-call="office_quest.quest_layout">

            <div class="text-center mb-5">
                <h1 class="quest-title">🏆 Hero Leaderboard</h1>
                <p class="quest-subtitle">WHO WILL CLAIM THE THRONE?</p>
            </div>

            <div class="row g-4">
                <t t-foreach="profiles" t-as="profile" t-foreach-index="profile_index">
                    <div class="col-md-6 col-lg-4">
                        <div t-attf-class="hero-card {{ profile_index == 0 and 'gold' or profile_index == 1 and 'silver' or profile_index == 2 and 'bronze' or '' }}">

                            <div class="d-flex align-items-center mb-2">
                                <t t-if="profile_index == 0">
                                    <span class="rank-medal">🥇</span>
                                </t>
                                <t t-if="profile_index == 1">
                                    <span class="rank-medal">🥈</span>
                                </t>
                                <t t-if="profile_index == 2">
                                    <span class="rank-medal">🥉</span>
                                </t>
                                <t t-if="profile_index &gt; 2">
                                    <span class="rank-medal" style="color:#555; font-size:1rem;">
                                        #<t t-out="profile_index + 1"/>
                                    </span>
                                </t>
                                <span class="hero-name">
                                    <t t-out="profile.name"/>
                                </span>
                            </div>

                            <div>
                                <t t-if="profile.hero_class == 'warrior'">
                                    <span class="hero-class-badge class-warrior">⚔️ WARRIOR</span>
                                </t>
                                <t t-if="profile.hero_class == 'wizard'">
                                    <span class="hero-class-badge class-wizard">🧙 WIZARD</span>
                                </t>
                                <t t-if="profile.hero_class == 'healer'">
                                    <span class="hero-class-badge class-healer">💚 HEALER</span>
                                </t>
                                <t t-if="profile.hero_class == 'rogue'">
                                    <span class="hero-class-badge class-rogue">🗡️ ROGUE</span>
                                </t>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span style="color:#aaa; font-size:0.85rem;">
                                    ⭐ Level <t t-out="profile.level"/>
                                </span>
                                <span class="xp-amount">
                                    ✨ <t t-out="profile.xp"/> XP
                                </span>
                            </div>

                            <t t-set="xp_in_level" t-value="profile.xp % 100"/>
                            <div class="xp-bar-wrap">
                                <div class="xp-bar-fill"
                                     t-attf-style="width: {{xp_in_level}}%;"/>
                            </div>
                            <div class="xp-text">
                                <t t-out="xp_in_level"/>/100 to next level
                            </div>

                            <t t-if="profile.badge_ids">
                                <div class="mt-3">
                                    <t t-foreach="profile.badge_ids" t-as="badge">
                                        <span class="quest-badge">
                                            <t t-out="badge.name"/>
                                        </span>
                                    </t>
                                </div>
                            </t>

                        </div>
                    </div>
                </t>

                <t t-if="not profiles">
                    <div class="empty-state">
                        ⚔️ No heroes yet. The throne awaits.
                    </div>
                </t>
            </div>

        </t>
    </template>

    <!-- MY PROFILE PAGE -->
    <template id="quest_my_profile" name="My Hero Profile">
        <t t-call="office_quest.quest_layout">
            <div class="row g-4">

                <!-- Profile Card -->
                <div class="col-md-4">
                    <div class="profile-card">
                        <div class="profile-avatar">
                            <t t-if="profile.hero_class == 'warrior'">⚔️</t>
                            <t t-if="profile.hero_class == 'wizard'">🧙</t>
                            <t t-if="profile.hero_class == 'healer'">💚</t>
                            <t t-if="profile.hero_class == 'rogue'">🗡️</t>
                        </div>
                        <div class="profile-name">
                            <t t-out="profile.name"/>
                        </div>
                        <div class="profile-level">
                            Level <t t-out="profile.level"/> Hero
                        </div>

                        <div class="mb-3">
                            <t t-if="profile.hero_class == 'warrior'">
                                <span class="hero-class-badge class-warrior">⚔️ WARRIOR</span>
                            </t>
                            <t t-if="profile.hero_class == 'wizard'">
                                <span class="hero-class-badge class-wizard">🧙 WIZARD</span>
                            </t>
                            <t t-if="profile.hero_class == 'healer'">
                                <span class="hero-class-badge class-healer">💚 HEALER</span>
                            </t>
                            <t t-if="profile.hero_class == 'rogue'">
                                <span class="hero-class-badge class-rogue">🗡️ ROGUE</span>
                            </t>
                        </div>

                        <div class="xp-amount mb-1">
                            ✨ <t t-out="profile.xp"/> XP
                        </div>

                        <t t-set="xp_in_level" t-value="profile.xp % 100"/>
                        <div class="xp-bar-wrap">
                            <div class="xp-bar-fill"
                                 t-attf-style="width: {{xp_in_level}}%;"/>
                        </div>
                        <div class="xp-text mb-3">
                            <t t-out="xp_in_level"/>/100 XP to next level
                        </div>

                        <!-- Earned Badges -->
                        <t t-if="profile.badge_ids">
                            <div class="mt-2">
                                <div style="color:#FFD700; font-weight:700; margin-bottom:8px;">
                                    🏆 Badges Earned
                                </div>
                                <t t-foreach="profile.badge_ids" t-as="badge">
                                    <span class="quest-badge">
                                        <t t-out="badge.name"/>
                                    </span>
                                </t>
                            </div>
                        </t>

                        <!-- Badge Progress Reminders -->
                        <t t-if="badge_progress">
                            <div class="mt-4">
                                <div style="color:#FFD700; font-weight:700; margin-bottom:12px;">
                                    🎯 Next Badge Goals
                                </div>
                                <t t-foreach="badge_progress" t-as="bp">
                                    <div style="margin-bottom: 14px;">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span style="color:#e0e0e0; font-size:0.85rem; font-weight:600;">
                                                <t t-out="bp['badge'].name"/>
                                            </span>
                                            <span style="font-size:0.75rem;">
                                                <t t-if="bp['type'] == 'xp'">
                                                    <span style="color:#e74c3c; font-weight:700;">
                                                        <t t-out="bp['remaining']"/> XP to go
                                                    </span>
                                                </t>
                                                <t t-if="bp['type'] == 'level'">
                                                    <span style="color:#e74c3c; font-weight:700;">
                                                        <t t-out="bp['remaining']"/> levels to go
                                                    </span>
                                                </t>
                                            </span>
                                        </div>
                                        <div class="badge-goal-bar">
                                            <div class="badge-goal-fill"
                                                 t-attf-style="width: {{bp['percent']}}%;"/>
                                        </div>
                                        <div class="xp-text mt-1">
                                            <t t-if="bp['type'] == 'xp'">
                                                <t t-out="bp['current']"/> /
                                                <t t-out="bp['needed']"/> XP
                                            </t>
                                            <t t-if="bp['type'] == 'level'">
                                                Level <t t-out="bp['current']"/> /
                                                <t t-out="bp['needed']"/>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <t t-if="not badge_progress">
                            <div class="mt-4" style="color:#2ecc71; font-size:0.85rem; text-align:center;">
                                🎉 All badges earned! You are a legend.
                            </div>
                        </t>

                    </div>
                </div>

                <!-- XP History -->
                <div class="col-md-8">
                    <div class="section-title">⚡ XP History</div>
                    <t t-if="logs">
                        <t t-foreach="logs" t-as="log">
                            <div t-attf-class="xp-log-item {{ log.xp_change &gt; 0 and 'positive' or 'negative' }}">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span t-attf-class="{{ log.xp_change &gt; 0 and 'xp-amount-positive' or 'xp-amount-negative' }}">
                                        <t t-if="log.xp_change &gt; 0">+</t>
                                        <t t-out="log.xp_change"/> XP
                                    </span>
                                    <span class="xp-log-date">
                                        <t t-out="log.create_date"/>
                                    </span>
                                </div>
                                <div class="xp-log-reason">
                                    <t t-out="log.reason"/>
                                </div>
                            </div>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="empty-state">
                            No XP events yet. Go do something heroic!
                        </div>
                    </t>
                </div>

            </div>
        </t>
    </template>

    <!-- MANAGE PAGE -->
    <template id="quest_manage" name="Quest Manager Panel">
        <t t-call="office_quest.quest_layout">

            <div class="mb-5">
                <h2 class="quest-title" style="font-size:2rem;">⚙️ Manager Panel</h2>
            </div>

            <!-- Heroes Table -->
            <div class="section-title">🦸 All Heroes</div>
            <div class="table-responsive mb-5">
                <table class="quest-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Hero</th>
                            <th>Class</th>
                            <th>Level</th>
                            <th>XP</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="profiles" t-as="profile">
                            <tr>
                                <td style="color:#555;">
                                    <t t-out="profile_index + 1"/>
                                </td>
                                <td class="fw-bold" style="color:#fff;">
                                    <t t-out="profile.name"/>
                                </td>
                                <td>
                                    <t t-if="profile.hero_class == 'warrior'">
                                        <span class="hero-class-badge class-warrior">⚔️ Warrior</span>
                                    </t>
                                    <t t-if="profile.hero_class == 'wizard'">
                                        <span class="hero-class-badge class-wizard">🧙 Wizard</span>
                                    </t>
                                    <t t-if="profile.hero_class == 'healer'">
                                        <span class="hero-class-badge class-healer">💚 Healer</span>
                                    </t>
                                    <t t-if="profile.hero_class == 'rogue'">
                                        <span class="hero-class-badge class-rogue">🗡️ Rogue</span>
                                    </t>
                                </td>
                                <td style="color:#FFD700;">
                                    ⭐ <t t-out="profile.level"/>
                                </td>
                                <td style="color:#FFD700; font-weight:700;">
                                    <t t-out="profile.xp"/>
                                </td>
                                <td>
                                    <t t-if="profile.is_active_player">
                                        <span class="badge-active">● Active</span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge-inactive">● Inactive</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- XP Events Table -->
            <div class="section-title">⚡ Recent XP Events</div>
            <div class="table-responsive">
                <table class="quest-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Hero</th>
                            <th>XP</th>
                            <th>Reason</th>
                            <th>Source</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="logs" t-as="log">
                            <tr t-attf-class="{{ log.xp_change &gt; 0 and 'positive' or 'negative' }}">
                                <td class="xp-log-date">
                                    <t t-out="log.create_date"/>
                                </td>
                                <td style="color:#fff; font-weight:600;">
                                    <t t-out="log.profile_id.name"/>
                                </td>
                                <td>
                                    <span t-attf-class="{{ log.xp_change &gt; 0 and 'xp-amount-positive' or 'xp-amount-negative' }}">
                                        <t t-if="log.xp_change &gt; 0">+</t>
                                        <t t-out="log.xp_change"/>
                                    </span>
                                </td>
                                <td style="color:#aaa;">
                                    <t t-out="log.reason"/>
                                </td>
                                <td style="color:#888; font-size:0.85rem;">
                                    <t t-out="log.source"/>
                                </td>
                                <td style="color:#888; font-size:0.85rem;">
                                    <t t-out="log.performed_by.name"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

        </t>
    </template>

</odoo>