<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- BADGE FORM VIEW -->
    <record id="view_game_badge_form" model="ir.ui.view">
        <field name="name">game.badge.form</field>
        <field name="model">game.badge</field>
        <field name="arch" type="xml">
            <form string="Badge">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Badge Name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="icon" widget="image"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- BADGE LIST VIEW -->
    <record id="view_game_badge_list" model="ir.ui.view">
        <field name="name">game.badge.list</field>
        <field name="model">game.badge</field>
        <field name="arch" type="xml">
            <list string="Badges">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- BADGE ACTION -->
    <record id="action_game_badge" model="ir.actions.act_window">
        <field name="name">Badges</field>
        <field name="res_model">game.badge</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Badge!
            </p>
        </field>
    </record>

    <!-- WIZARD VIEW -->
    <record id="view_award_xp_wizard_form" model="ir.ui.view">
        <field name="name">game.award.xp.wizard.form</field>
        <field name="model">game.award.xp.wizard</field>
        <field name="arch" type="xml">
            <form string="Award Bonus XP">
                <group>
                    <field name="profile_id"/>
                    <field name="xp_amount"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_award_xp"
                            string="Award XP"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- WIZARD ACTION -->
    <record id="action_award_xp_wizard" model="ir.actions.act_window">
        <field name="name">Award Bonus XP</field>
        <field name="res_model">game.award.xp.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_game_profile_kanban" model="ir.ui.view">
        <field name="name">game.profile.kanban</field>
        <field name="model">game.profile</field>
        <field name="arch" type="xml">
            <kanban default_group_by="hero_class"
                    default_order="xp desc">

                <field name="name"/>
                <field name="hero_class"/>
                <field name="level"/>
                <field name="xp"/>
                <field name="is_active_player"/>
                <field name="badge_ids"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">

                            <!-- Hero Class Emoji + Name -->
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <t t-if="record.hero_class.value == 'warrior'">⚔️ </t>
                                        <t t-if="record.hero_class.value == 'wizard'">🧙 </t>
                                        <t t-if="record.hero_class.value == 'healer'">💚 </t>
                                        <t t-if="record.hero_class.value == 'rogue'">🗡️ </t>
                                        <field name="name"/>
                                    </strong>
                                    <br/>
                                    <field name="hero_class" widget="badge"/>
                                </div>
                            </div>

                            <!-- Stats -->
                            <div class="o_kanban_record_body">
                                <div>⭐ Level: <field name="level"/></div>
                                <div>✨ XP: <field name="xp"/></div>
                            </div>

                            <!-- Badges -->
                            <div class="o_kanban_record_body" t-if="record.badge_ids.raw_value.length">
                                <div>🏆 Badges:</div>
                                <field name="badge_ids" widget="many2many_tags"/>
                            </div>

                            <!-- Active toggle -->
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="is_active_player" widget="boolean_toggle"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- GAME PROFILE FORM VIEW -->
    <record id="view_game_profile_form" model="ir.ui.view">
        <field name="name">game.profile.form</field>
        <field name="model">game.profile</field>
        <field name="arch" type="xml">
            <form string="Hero Profile">
                <header>
                    <button name="%(office_quest.action_award_xp_wizard)d"
                            string="Award Bonus XP"
                            type="action"
                            class="btn-primary"
                            groups="office_quest.group_office_quest_manager"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Hero Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Character">
                            <field name="hero_class"/>
                            <field name="level" readonly="True"/>
                            <field name="xp"/>
                            <field name="is_active_player"/>
                        </group>
                        <group string="About">
                            <field name="bio"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Badges">
                            <field name="badge_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- GAME PROFILE LIST VIEW -->
    <record id="view_game_profile_list" model="ir.ui.view">
        <field name="name">game.profile.list</field>
        <field name="model">game.profile</field>
        <field name="arch" type="xml">
            <list string="Heroes">
                <field name="name"/>
                <field name="hero_class"/>
                <field name="level"/>
                <field name="xp"/>
                <field name="is_active_player"/>
            </list>
        </field>
    </record>

    <!-- GAME PROFILE SEARCH VIEW -->
    <record id="view_game_profile_search" model="ir.ui.view">
        <field name="name">game.profile.search</field>
        <field name="model">game.profile</field>
        <field name="arch" type="xml">
            <search string="Search Heroes">
                <field name="name"/>
                <field name="hero_class"/>
                <filter name="active_players"
                        string="Active Players"
                        domain="[('is_active_player', '=', True)]"/>
                <filter name="group_by_class"
                        string="Class"
                        context="{'group_by': 'hero_class'}"
                        groups="base.group_user"/>
            </search>
        </field>
    </record>

    <!-- GAME PROFILE ACTION -->
    <record id="action_game_profile" model="ir.actions.act_window">
        <field name="name">Heroes</field>
        <field name="res_model">game.profile</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_game_profile_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Hero!
            </p>
        </field>
    </record>

    <!-- MENU ITEMS -->
    <menuitem id="menu_office_quest_root"
              name="Office Quest"
              sequence="10"/>

    <menuitem id="menu_office_quest_heroes"
              name="Heroes"
              parent="menu_office_quest_root"
              action="action_game_profile"
              sequence="10"/>

    <menuitem id="menu_office_quest_badges"
              name="Badges"
              parent="menu_office_quest_root"
              action="action_game_badge"
              sequence="20"/>

    <menuitem id="menu_office_quest_leaderboard"
              name="Leaderboard"
              parent="menu_office_quest_root"
              action="action_game_profile"
              sequence="30"/>

    <!-- INHERIT RES.USERS FORM -->
    <record id="view_res_users_form_inherit" model="ir.ui.view">
        <field name="name">res.users.form.inherit.office_quest</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <group string="Office Quest">
                    <field name="profile_id"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>